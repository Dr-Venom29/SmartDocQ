# Node API server environment
PORT=5000
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
JWT_SECRET=replace-with-strong-secret

# Allowed frontend origins (comma-separated). Support exact URLs and wildcard subdomains with a leading dot (e.g., *.vercel.app)
FRONTEND_ORIGINS=http://localhost:3000, https://your-frontend.vercel.app

# Cloudinary (optional, for avatars)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_AVATAR_FOLDER=smartdoc/avatars

# Service-to-service token (used by Flask to download documents)
# Must be a strong random secret and must match backend/.env SERVICE_TOKEN
SERVICE_TOKEN=

# Flask service URLs
FLASK_ASK_URL=https://your-flask-service.example.com/api/document/ask
FLASK_INDEX_URL=https://your-flask-service.example.com/api/index-from-atlas
FLASK_CONVERT_URL=https://your-flask-service.example.com/api/convert/word-to-pdf

# Frontend Base URL (used when generating password-reset links)
FRONTEND_URL=http://localhost:3000

# Email configurations
# - Development (Gmail SMTP):
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-google-app-password

# - Production (Brevo SMTP):
BREVO_MAIL_USER=your-brevo-smtp-login
BREVO_MAIL_PASS=your-brevo-smtp-key
# BREVO_MAIL_SENDER=smartdocq@gmail.com
# BREVO_MAIL_HOST=smtp-relay.brevo.com
# BREVO_MAIL_PORT=587 (or try 465 or 2525 if blocked)
# BREVO_MAIL_SECURE=false (use true if using port 465)
